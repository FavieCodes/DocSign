# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Google OAuth2 Credentials
# Create a project at https://console.cloud.google.com/
# Add 'http://localhost:8000/auth/google/callback/' as an Authorized Redirect URI.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP Email (for sending verification codes)
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Database (leave blank for local SQLite, set for production Postgres)
# Vercel auto-injects DATABASE_URL when you link a Postgres store
# DATABASE_URL=postgres://user:pass@host:5432/dbname